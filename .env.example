# MT5 Connection (leave blank to use already-open terminal)
MT5_LOGIN=12345678
MT5_PASSWORD=your_password
MT5_SERVER=YourBroker-Server
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# Storage
DATA_PATH=data/mt5

# Default symbols to watch
DEFAULT_SYMBOLS=["XAUUSD", "EURUSD", "USDJPY", "GBPUSD"]
DEFAULT_TIMEFRAMES=["M1", "M5", "H1", "D1"]

# API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Cache
CACHE_MAX_SIZE=50

# Download
MAX_RETRIES=3
RETRY_DELAY_SECONDS=2.0
BATCH_SIZE=100000

# DuckDB
DUCKDB_ENABLED=true

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_TICK_MAXLEN=50000
REDIS_BAR_MAXLEN=10000
